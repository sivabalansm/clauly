# Anthropic — required for analysis (redline / discussion / risks)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — required for live transcription (Whisper)
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
# Alternatives: gpt-4o-mini-transcribe (faster/cheaper), gpt-4o-transcribe (most accurate)

# Optional tuning
TRANSCRIPTION_CHUNK_MS=6000
ANALYSIS_TEMPERATURE=0.2
